# SMTP config for contact form
# Works with any SMTP provider (Gmail, Zoho, SendGrid, etc.)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password

# Where to deliver the enquiry emails (defaults to info@metalbarns.in)
CONTACT_TO=info@metalbarns.in
